MCP_GATEWAY_HOST=0.0.0.0
MCP_GATEWAY_PORT=3000
# Some hosts provide PORT automatically. MCP_GATEWAY_PORT takes precedence.
PORT=3000

# Set this to your public HTTPS app URL in hosted deployments.
MCP_GATEWAY_PUBLIC_URL=

# Required in hosted/Docker deployments. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MCP_GATEWAY_SECRET_KEY=

# Optional. If unset, the gateway persists to local data/*.json and data/*.jsonl files.
DATABASE_URL=

# Set to true for managed Postgres providers that require SSL.
DATABASE_SSL=false
